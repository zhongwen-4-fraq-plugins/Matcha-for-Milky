{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fraq Debug",
  "version": "0.1.0",
  "identifier": "dev.fraq.debug",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Fraq Debug",
        "width": 1280,
        "height": 820,
        "minWidth": 760,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
